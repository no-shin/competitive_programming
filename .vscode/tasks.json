{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build",
            "type": "shell",
            "command": "g++",
            "args": [
                "-std=c++23",
                "-g",
                "-O0",
                "-Wall",
                "-Wextra",
                "-o",
                "${fileDirname}/main",
                "${file}"
            ],
            "options": {
                "cwd": "${fileDirname}"
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": [
                "$gcc"
            ]
        },
        {
            "label": "Test",
            "type": "shell",
            "command": "${workspaceFolder}/.venv/bin/atcoder-tools",
            "args": [
                "test"
            ],
            "options": {
                "cwd": "${fileDirname}"
            }
        },
        {
            "label": "Submit",
            "type": "shell",
            "command": "${workspaceFolder}/.venv/bin/atcoder-tools",
            "args": [
                "submit"
            ],
            "options": {
                "cwd": "${fileDirname}"
            }
        }
    ]
}
